{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/send_email.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/status.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/contacts.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/logs.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/automation.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/bulk_send.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/settings.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/api/send_email",
      "dest": "/api/send_email.py"
    },
    {
      "src": "/api/status",
      "dest": "/api/status.py"
    },
    {
      "src": "/api/contacts",
      "dest": "/api/contacts.py"
    },
    {
      "src": "/api/logs",
      "dest": "/api/logs.py"
    },
    {
      "src": "/api/automation",
      "dest": "/api/automation.py"
    },
    {
      "src": "/api/bulk_send",
      "dest": "/api/bulk_send.py"
    },
    {
      "src": "/api/settings",
      "dest": "/api/settings.py"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
